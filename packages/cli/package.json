{
  "name": "compliancemaxx",
  "version": "2.0.2",
  "description": "Multi-framework compliance orchestrator (OSS-license, OWASP ASVS, ISO 27001, SOC 2, GDPR) for repo and CI/CD.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/erp-mafia/compliancemaxx#readme",
  "bugs": "https://github.com/erp-mafia/compliancemaxx/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erp-mafia/compliancemaxx.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "compliance",
    "soc2",
    "iso27001",
    "gdpr",
    "owasp",
    "asvs",
    "sast",
    "sbom",
    "ci",
    "audit",
    "sarif"
  ],
  "type": "module",
  "main": "./dist/src/orchestrator.js",
  "types": "./dist/src/orchestrator.d.ts",
  "bin": {
    "compliancemaxx": "dist/bin/compliancemaxx.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/orchestrator.d.ts",
      "import": "./dist/src/orchestrator.js"
    },
    "./schema": {
      "types": "./dist/src/findings/schema.d.ts",
      "import": "./dist/src/findings/schema.js"
    },
    "./manifest": {
      "types": "./dist/src/skills/manifest.d.ts",
      "import": "./dist/src/skills/manifest.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx bin/compliancemaxx.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "bundle:skills": "rm -rf skills && cp -R ../skills skills",
    "clean": "rm -rf dist skills",
    "prepack": "npm run clean && npm run build && npm run bundle:skills"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.29.0",
    "@anthropic-ai/sdk": "^0.95.0",
    "fast-glob": "^3.3.2",
    "minimatch": "^10.0.0",
    "yaml": "^2.6.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.21.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
